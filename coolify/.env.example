# Copier ce fichier vers /data/coolify/source/.env sur l'hôte Linux qui
# exécutera `docker compose up` (voir docs/infrastructure-setup.md), puis
# remplacer les valeurs ci-dessous par des secrets générés localement.
# Ne jamais committer le .env réel (voir .gitignore).

APP_ENV=production
APP_NAME=Coolify
APP_ID=CHANGE_ME_random_id
APP_KEY=base64:CHANGE_ME_$(openssl rand -base64 32)
APP_PORT=8000

DB_USERNAME=coolify
DB_PASSWORD=CHANGE_ME_$(openssl rand -hex 32)
DB_DATABASE=coolify

REDIS_PASSWORD=CHANGE_ME_$(openssl rand -hex 32)

PUSHER_APP_ID=CHANGE_ME_$(openssl rand -hex 16)
PUSHER_APP_KEY=CHANGE_ME_$(openssl rand -hex 16)
PUSHER_APP_SECRET=CHANGE_ME_$(openssl rand -hex 16)
SOKETI_PORT=6001
